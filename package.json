{
  "name": "can-you-run-it",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:all": "npm run server & npm run dev",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "agent:test": "node agent-cjs.js",
    "agent:build": "pkg agent-cjs.js --targets node18-win-x64 --output dist-agent/CYRI-Agent.exe",
    "agent:install-pkg": "npm install -g pkg",
    "agent:setup": "npm run agent:install-pkg && npm install systeminformation axios && npm run agent:build"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.14.0",
    "systeminformation": "^5.31.5",
    "vercel": "^50.41.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist-agent"
  }
}
